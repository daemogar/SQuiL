<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Lock restore to nuget.org: machine/user-level configs on dev machines may
       add intranet feeds that are unreachable (or slow) and break restore. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
